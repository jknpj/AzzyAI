    {
      "label": "Build AzzyAIConfig Release",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "GUI/AzzyAIConfig/AzzyAIConfig.csproj",
        "--configuration",
        "Release"
      ],
      "group": "build",
      "problemMatcher": ["$msCompile"],
      "isBackground": false
    },
    {
      "label": "Run AzzyAIConfig",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "GUI/AzzyAIConfig/AzzyAIConfig.csproj",
        "--configuration",
        "Debug"
      ],
      "group": "build",
      "problemMatcher": [],
      "isBackground": false
