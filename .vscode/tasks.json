{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build AzzyAIConfig",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "GUI/AzzyAIConfig/AzzyAIConfig.csproj",
        "--configuration",
        "Debug"
      ],
      "group": "build",
      "problemMatcher": ["$msCompile"],
      "isBackground": false
    },
    {
      "label": "Build AzzyAIConfig Release",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "GUI/AzzyAIConfig/AzzyAIConfig.csproj",
        "--configuration",
        "Release"
      ],
      "group": "build",
      "problemMatcher": ["$msCompile"],
      "isBackground": false
    },
    {
      "label": "Run AzzyAIConfig",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "GUI/AzzyAIConfig/AzzyAIConfig.csproj",
        "--configuration",
        "Debug"
      ],
      "group": "build",
      "problemMatcher": [],
      "isBackground": false
    },
    {
      "label": "Publish Single File (Self-Contained)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "publish",
        "--configuration",
        "Release",
        "--runtime",
        "win-x86",
        "--self-contained",
        "true",
        "-p:PublishSingleFile=true"
      ],
      "options": {
        "cwd": "${workspaceFolder}/GUI/AzzyAIConfig"
      },
      "group": "build",
      "problemMatcher": ["$msCompile"],
      "isBackground": false
    }
  ]
}
