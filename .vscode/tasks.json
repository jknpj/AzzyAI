{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build AzzyAI Config - Debug",
      "type": "shell",
      "command": "C:\\WINDOWS\\Microsoft.NET\\Framework\\v4.0.30319\\MSBuild.exe",
      "args": [
        "${workspaceFolder}\\GUI\\AzzyAIConfig\\AzzyAIConfig.csproj",
        "/p:Configuration=Debug",
        "/p:Platform=x86",
        "/verbosity:minimal"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "options": {
        "cwd": "${workspaceFolder}\\GUI\\AzzyAIConfig"
      },
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Build AzzyAI Config - Release",
      "type": "shell",
      "command": "C:\\WINDOWS\\Microsoft.NET\\Framework\\v4.0.30319\\MSBuild.exe",
      "args": [
        "${workspaceFolder}\\GUI\\AzzyAIConfig\\AzzyAIConfig.csproj",
        "/p:Configuration=Release",
        "/p:Platform=x86",
        "/verbosity:minimal"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "options": {
        "cwd": "${workspaceFolder}\\GUI\\AzzyAIConfig"
      },
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Clean AzzyAI Config",
      "type": "shell",
      "command": "C:\\WINDOWS\\Microsoft.NET\\Framework\\v4.0.30319\\MSBuild.exe",
      "args": [
        "${workspaceFolder}\\GUI\\AzzyAIConfig\\AzzyAIConfig.csproj",
        "/t:Clean",
        "/p:Configuration=Debug",
        "/p:Platform=x86"
      ],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "options": {
        "cwd": "${workspaceFolder}\\GUI\\AzzyAIConfig"
      },
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "Run AzzyAI Config - Debug",
      "type": "shell",
      "command": "${workspaceFolder}\\GUI\\AzzyAIConfig\\bin\\Debug\\AzzyAIConfig.exe",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "options": {
        "cwd": "${workspaceFolder}\\GUI\\AzzyAIConfig\\bin\\Debug"
      },
      "dependsOn": "Build AzzyAI Config - Debug"
    },
    {
      "label": "Build and Run AzzyAI Config",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Build AzzyAI Config - Debug",
        "Run AzzyAI Config - Debug"
      ],
      "group": "build"
    }
  ]
}
